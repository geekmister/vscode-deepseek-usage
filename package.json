{
    "name": "vscode-deepseek-usage",
    "displayName": "DeepSeek Usage Monitor",
    "publisher": "Geekmister",
    "version": "1.0.0",
    "description": "Monitor DeepSeek API balance, token usage and costs — with QuickPick preview and Chart.js dashboard",
    "license": "MIT",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Visualization",
        "Data Science",
        "Other"
    ],
    "keywords": [
        "DeepSeek",
        "token usage",
        "API monitor",
        "balance",
        "cost tracking",
        "dashboard"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "DeepSeek Usage Monitor",
            "properties": {
                "deepseek.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "DeepSeek API Key"
                },
                "deepseek.autoRefreshInterval": {
                    "type": "number",
                    "default": 30,
                    "description": "自动刷新间隔（分钟）"
                },
                "deepseek.cacheTTL": {
                    "type": "number",
                    "default": 5,
                    "minimum": 1,
                    "maximum": 60,
                    "description": "余额缓存时间（分钟）"
                }
            }
        },
        "commands": [
            {
                "command": "deepseek-usage.showUsage",
                "title": "DeepSeek: 打开用量概览"
            },
            {
                "command": "deepseek-usage.refresh",
                "title": "DeepSeek: 刷新数据"
            },
            {
                "command": "deepseek-usage.setPlatformToken",
                "title": "DeepSeek: 设置平台 Token（用量统计）"
            },
            {
                "command": "deepseek-usage.clearPlatformToken",
                "title": "DeepSeek: 清除平台 Token"
            },
            {
                "command": "deepseek-usage.openDashboard",
                "title": "DeepSeek: 打开完整仪表盘（编辑器 Tab）"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
        "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
        "package": "vsce package"
    },
    "dependencies": {
        "axios": "^1.7.0"
    },
    "devDependencies": {
        "@types/vscode": "^1.90.0",
        "typescript": "^5.5.0",
        "esbuild": "^0.23.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Geekmister/vscode-deepseek-usage"
    }
}
